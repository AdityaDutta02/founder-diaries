{
  "expo": {
    "name": "Founder Diaries",
    "slug": "founder-diaries",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "founder-diaries",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#6366F1"
    },
    "notifications": {
      "icon": "./assets/icon.png",
      "color": "#6366f1",
      "sounds": []
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.founderdiaries.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Founder Diaries needs microphone access to record voice diary entries.",
        "NSCameraUsageDescription": "Founder Diaries needs camera access to add photos to diary entries.",
        "NSPhotoLibraryUsageDescription": "Founder Diaries needs photo library access to attach images to diary entries.",
        "NSUserNotificationsUsageDescription": "We send friendly reminders to write diary entries and occasional questions to help personalise your content."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#6366F1",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.founderdiaries.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.WAKE_LOCK"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-image",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "Allow Founder Diaries to access your microphone for voice diary entries."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Founder Diaries to access your photos for diary entries.",
          "cameraPermission": "Allow Founder Diaries to use your camera for diary entries."
        }
      ],
      "expo-background-fetch",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#6366f1"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "30df0879-bed8-400b-a7e5-987a4ea5495e"
      }
    },
    "owner": "aditya001_1"
  }
}
