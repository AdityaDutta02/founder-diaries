{
  "name": "founder-diaries",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "npx expo export --platform web",
    "test": "jest",
    "lint": "expo lint"
  },
  "dependencies": {
