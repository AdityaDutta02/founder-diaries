    "@tanstack/react-query": "^5.90.21",
    "date-fns": "^4.1.0",
    "expo": "~55.0.6",
    "expo-av": "^16.0.8",
    "expo-background-fetch": "~55.0.9",
    "expo-constants": "~55.0.7",
    "expo-crypto": "~55.0.9",
    "expo-file-system": "~55.0.10",
    "expo-font": "^55.0.4",
    "expo-image": "~55.0.6",
    "expo-image-picker": "~55.0.12",
    "expo-linking": "~55.0.7",
    "expo-notifications": "~55.0.12",
    "expo-print": "~55.0.8",
    "expo-router": "~55.0.5",
    "expo-secure-store": "~55.0.8",
    "expo-sharing": "~55.0.11",
    "expo-sqlite": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "jest-expo": "~55.0.14",
    "posthog-react-native": "^4.40.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~55.0.0",
    "jest": "^29.7.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "./jest.setup.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|react-native-reanimated|react-native-worklets)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/.worktrees/"
    ]
  }
